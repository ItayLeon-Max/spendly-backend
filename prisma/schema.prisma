generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ExpenseMood {
  happy
  stressed
  spontaneous
  tired
  treatingMyself
}

enum AppLanguage {
  english
  hebrew
}

enum SharedBudgetMemberRole {
  owner
  member
}

enum SharedBudgetInviteStatus {
  pending
  accepted
  declined
}

model User {
  id                       String                   @id @default(uuid())
  fullName                 String
  email                    String                   @unique
  passwordHash             String
  monthlyBudget            Float                    @default(0)
  monthlyIncome            Float?
  managedBudget            Float?
  profileImage             String?

  pushToken                String?                  @db.Text
  pushNotificationsEnabled Boolean                  @default(true)
  preferredLanguage        AppLanguage              @default(english)
  lastPushSentAt           DateTime?
  createdAt                DateTime                 @default(now())

  expenses                 Expense[]
  customCategories         UserCustomCategory[]
  budgetAllocations        BudgetAllocation[]

  ownedSharedBudgets       SharedBudget[]           @relation("SharedBudgetOwner")
  sharedBudgetMemberships  SharedBudgetMember[]
  sentSharedBudgetInvites  SharedBudgetInvite[]     @relation("SharedBudgetInviteSender")
  receivedSharedBudgetInvites SharedBudgetInvite[]  @relation("SharedBudgetInviteRecipient")
}

model SharedBudget {
  id                String                @id @default(uuid())
  name              String
  totalBudget       Float
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  ownerId           String
  owner             User                  @relation("SharedBudgetOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members           SharedBudgetMember[]
  invites           SharedBudgetInvite[]
  expenses          Expense[]
  budgetAllocations BudgetAllocation[]

  @@index([ownerId])
}

model SharedBudgetMember {
  id              String                  @id @default(uuid())
  role            SharedBudgetMemberRole  @default(member)
  createdAt       DateTime                @default(now())

  sharedBudgetId  String
  sharedBudget    SharedBudget            @relation(fields: [sharedBudgetId], references: [id], onDelete: Cascade)

  userId          String
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sharedBudgetId, userId])
  @@index([sharedBudgetId])
  @@index([userId])
}

model SharedBudgetInvite {
  id              String                    @id @default(uuid())
  status          SharedBudgetInviteStatus  @default(pending)
  createdAt       DateTime                  @default(now())
  respondedAt     DateTime?

  sharedBudgetId  String
  sharedBudget    SharedBudget              @relation(fields: [sharedBudgetId], references: [id], onDelete: Cascade)

  invitedByUserId String
  invitedByUser   User                      @relation("SharedBudgetInviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  invitedUserId   String
  invitedUser     User                      @relation("SharedBudgetInviteRecipient", fields: [invitedUserId], references: [id], onDelete: Cascade)

  @@unique([sharedBudgetId, invitedUserId])
  @@index([sharedBudgetId])
  @@index([invitedByUserId])
  @@index([invitedUserId])
  @@index([status])
}

model Expense {
  id              String        @id @default(uuid())
  title           String
  amount          Float
  category        String
  mood            ExpenseMood?
  isNeed          Boolean       @default(true)
  date            DateTime      @default(now())
  createdAt       DateTime      @default(now())

  isRecurring               Boolean   @default(false)
  recurringFrequency        String?
  installmentCount          Int?
  isOngoing                 Boolean   @default(false)
  recurringGroupId          String?
  originalTotalAmount       Float?
  totalInstallments         Int?
  currentInstallmentNumber  Int?
  remainingInstallments     Int?
  nextRecurringDate         DateTime?

  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  sharedBudgetId  String?
  sharedBudget    SharedBudget? @relation(fields: [sharedBudgetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sharedBudgetId])
}

model UserCustomCategory {
  id                  String    @id @default(uuid())
  name                String
  icon                String
  iconBackgroundColor String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model BudgetAllocation {
  id              String        @id @default(uuid())
  category        String
  amount          Float
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  sharedBudgetId  String?
  sharedBudget    SharedBudget? @relation(fields: [sharedBudgetId], references: [id], onDelete: Cascade)

  @@unique([userId, category, sharedBudgetId])
  @@index([userId])
  @@index([sharedBudgetId])
}