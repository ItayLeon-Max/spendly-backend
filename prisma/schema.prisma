generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ExpenseMood {
  happy
  stressed
  spontaneous
  tired
  treatingMyself
}

model User {
  id                String             @id @default(uuid())
  fullName          String
  email             String             @unique
  passwordHash      String
  monthlyBudget     Float              @default(0)
  monthlyIncome     Float?
  managedBudget     Float?
  profileImage      String?
  createdAt         DateTime           @default(now())
  expenses          Expense[]
  budgetAllocations BudgetAllocation[]
}

model Expense {
  id         String       @id @default(uuid())
  title      String
  amount     Float
  category   String
  mood       ExpenseMood?
  isNeed     Boolean      @default(true)
  date       DateTime     @default(now())
  createdAt  DateTime     @default(now())

  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BudgetAllocation {
  id         String   @id @default(uuid())
  category   String
  amount     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
}